-- Função que cria a animação do Toast
local function S7xNotify(title, text)
    local notif = Instance.new("Frame", GUI.NotifyContainer)
    notif.Size = UDim2.new(1, 0, 0, 45)
    notif.BackgroundColor3 = Color3.fromRGB(15, 12, 20)
    notif.BackgroundTransparency = 1
    Instance.new("UICorner", notif).CornerRadius = UDim.new(0, 6)
    
    local strk = Instance.new("UIStroke", notif)
    strk.Color = Color3.fromRGB(170, 0, 255)
    strk.Thickness = 1.2
    strk.Transparency = 1
    
    local titleLbl = Instance.new("TextLabel", notif)
    titleLbl.Size = UDim2.new(1, -15, 0, 20)
    titleLbl.Position = UDim2.new(0, 10, 0, 5)
    titleLbl.BackgroundTransparency = 1
    titleLbl.Text = title
    titleLbl.TextColor3 = Color3.fromRGB(170, 0, 255)
    titleLbl.Font = Enum.Font.GothamBlack
    titleLbl.TextSize = 11
    titleLbl.TextXAlignment = Enum.TextXAlignment.Left
    titleLbl.TextTransparency = 1
    
    local descLbl = Instance.new("TextLabel", notif)
    descLbl.Size = UDim2.new(1, -15, 0, 20)
    descLbl.Position = UDim2.new(0, 10, 0, 20)
    descLbl.BackgroundTransparency = 1
    descLbl.Text = text
    descLbl.TextColor3 = Color3.fromRGB(200, 200, 210)
    descLbl.Font = Enum.Font.GothamBold
    descLbl.TextSize = 11
    descLbl.TextXAlignment = Enum.TextXAlignment.Left
    descLbl.TextTransparency = 1
    
    -- Animação de Entrada
    pcall(function()
        local ts = game:GetService("TweenService")
        ts:Create(notif, TweenInfo.new(0.3, Enum.EasingStyle.Quint), {BackgroundTransparency = 0.1}):Play()
        ts:Create(strk, TweenInfo.new(0.3), {Transparency = 0}):Play()
        ts:Create(titleLbl, TweenInfo.new(0.3), {TextTransparency = 0}):Play()
        ts:Create(descLbl, TweenInfo.new(0.3), {TextTransparency = 0}):Play()
    end)
    
    -- Animação de Saída e Destruição
    task.delay(2.5, function()
        pcall(function()
            local ts = game:GetService("TweenService")
            ts:Create(notif, TweenInfo.new(0.3, Enum.EasingStyle.Quint), {BackgroundTransparency = 1}):Play()
            ts:Create(strk, TweenInfo.new(0.3), {Transparency = 1}):Play()
            ts:Create(titleLbl, TweenInfo.new(0.3), {TextTransparency = 1}):Play()
            ts:Create(descLbl, TweenInfo.new(0.3), {TextTransparency = 1}):Play()
        end)
        task.wait(0.35)
        if notif then notif:Destroy() end
    end)
end

