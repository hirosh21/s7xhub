    elseif type(http_request) == "function" then reqFunc = http_request
    elseif type(http) == "table" and type(http.request) == "function" then reqFunc = http.request
    elseif type(syn) == "table" and type(syn.request) == "function" then reqFunc = syn.request
    elseif type(fluxus) == "table" and type(fluxus.request) == "function" then reqFunc = fluxus.request
    end
    
    if not reqFunc then return nil end
    
    options.Headers = options.Headers or {}
    options.Headers["Content-Type"] = "application/json"
    options.Headers["User-Agent"] = "Roblox/S7xHub-Premium"
    
    local success, result = pcall(function() return reqFunc(options) end)
    return success and result or nil
end

