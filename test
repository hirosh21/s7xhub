local function parseColor(c, def)
    if type(c) == "string" then
        c = string.gsub(c, " ", "")
        if string.sub(c, 1, 1) == "#" then
            local s, hexColor = pcall(function() return Color3.fromHex(c) end)
            if s then return hexColor end
        end
        local r, g, b = string.match(c, "(%d+)[^%d]+(%d+)[^%d]+(%d+)")
        if r and g and b then return Color3.fromRGB(tonumber(r), tonumber(g), tonumber(b)) end
    end
    return def
end

