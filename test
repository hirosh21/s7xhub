            ["Authorization"] = "Bearer " .. SUPABASE_KEY,
            ["Content-Type"] = "application/json",
            ["Prefer"] = "resolution=merge-duplicates"
        }
    }
    if body then options.Body = game:GetService("HttpService"):JSONEncode(body) end
    local s, res = pcall(function() return req(options) end)
    if s and res and res.StatusCode >= 200 and res.StatusCode < 300 then return res.Body end
    return nil
end

