local function StopTargetAnim()
    if activeTargetAnim then activeTargetAnim:Stop(); activeTargetAnim = nil end
end

local function PlayTargetAnim(animId)
    local char = player.Character
    local hum = char and char:FindFirstChild("Humanoid")
    if hum then
        StopTargetAnim()
        pcall(function()
            local anim = Instance.new("Animation")
            anim.AnimationId = "rbxassetid://" .. tostring(animId)
            activeTargetAnim = hum:LoadAnimation(anim)
            activeTargetAnim:Play()
        end)
    end
end

local function clearTargetState()
