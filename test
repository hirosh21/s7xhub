task.spawn(function()
    while task.wait(0.1) do
        if _G.SyncEmoteEnabled and spectatingPlayer and spectatingPlayer.Character then
            pcall(function()
                local myChar = game.Players.LocalPlayer.Character
                local myAnim = myChar and myChar:FindFirstChildOfClass("Humanoid") and myChar.Humanoid:FindFirstChildOfClass("Animator")
                
                local tChar = spectatingPlayer.Character
                local tAnim = tChar and tChar:FindFirstChildOfClass("Humanoid") and tChar.Humanoid:FindFirstChildOfClass("Animator")
                
                if myAnim and tAnim then
                    local tTracks = tAnim:GetPlayingAnimationTracks()
                    local currentlyPlaying = {}
                    
                    for _, track in ipairs(tTracks) do
                        if track.Animation and track.Animation.AnimationId then
                            local id = track.Animation.AnimationId
                            currentlyPlaying[id] = true
                            
                            if not _G.ActiveSyncTracks[id] then
                                if track.Priority == Enum.AnimationPriority.Action or track.Priority == Enum.AnimationPriority.Action2 or track.Priority == Enum.AnimationPriority.Action3 then
