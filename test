-- Filtro limpador de lixo JSON (Remove aspas duplas e simples que quebram as cores)
local function CleanVal(v)
    if type(v) == "string" then return string.gsub(v, '["\']', "") end
    return v
end

-- Interpretador Global de Cores Seguro
_G.S7xParseColor = function(c, defaultColor)
    if typeof(c) == "Color3" then return c end
    if type(c) == "string" then
        c = string.gsub(c, '["\' %[%]{}]', "") 
        local s, res = pcall(function() return Color3.fromHex(c) end)
        if s and res then return res end
        
        local hex = string.match(c, "%x%x%x%x%x%x")
        if hex then
            local r = tonumber(string.sub(hex, 1, 2), 16)
            local g = tonumber(string.sub(hex, 3, 4), 16)
            local b = tonumber(string.sub(hex, 5, 6), 16)
            if r and g and b then return Color3.fromRGB(r, g, b) end
        end
    end
    return defaultColor or Color3.fromRGB(255, 255, 255)
end

-- Motor HTTP Blindado
_G.SupabaseReq = function(endpoint, method, body)
    local options = {
        Url = SUPABASE_URL .. endpoint,
        Method = method or "GET",
        Headers = {
            ["apikey"] = SUPABASE_KEY,
            ["Authorization"] = "Bearer " .. SUPABASE_KEY,
            ["Content-Type"] = "application/json",
            ["Prefer"] = (method == "POST" or method == "PATCH") and "resolution=merge-duplicates" or "return=representation"
        }
    }
    if body then options.Body = game:GetService("HttpService"):JSONEncode(body) end
    
    local reqFunc = (syn and syn.request) or http_request or request or (fluxus and fluxus.request)
    if not reqFunc then return nil end
    local success, result = pcall(function() return reqFunc(options) end)
    return success and result or nil
end

