                if hum_resync then
                    oldDist_resync = hum_resync.DisplayDistanceType
                    hum_resync.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None
                    task.wait()
                    hum_resync.DisplayDistanceType = (oldDist_resync ~= Enum.HumanoidDisplayDistanceType.None) and oldDist_resync or Enum.HumanoidDisplayDistanceType.Viewer
                end
                
                -- 2. Limpa a Tag S7x da cabeça para forçar uma reconstrução limpa
                head_resync = p.Character:FindFirstChild("Head") or p.Character:FindFirstChild("HumanoidRootPart")
                if head_resync then
                    for _, v in ipairs(head_resync:GetChildren()) do
                        if v.Name == "S7x_ProTag" then v:Destroy() end
                    end
                end
                
                -- 3. Reconstrói a tag visualmente
                if ApplyOrUpdateTag then ApplyOrUpdateTag(p) end
            end
        end
    end)
