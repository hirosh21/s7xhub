ApplyOrUpdateTag = function(targetPlayer)
    if not S7xUsers[targetPlayer.UserId] then return end
    
    local char_tgt = targetPlayer.Character
    if not char_tgt or (char_tgt:FindFirstChild("Humanoid") and char_tgt.Humanoid.Health <= 0) then return end
    
    local head_tgt = char_tgt:WaitForChild("Head", 3) or char_tgt:FindFirstChild("HumanoidRootPart")
    if not head_tgt then return end

    local fRank = GetFirebaseRank(targetPlayer) or "User"
    if fRank == "Creator" then fRank = "Owner" end
    if fRank == "Developers" or fRank == "Dev" then fRank = "Developer" end

    local rankName_tgt = fRank
    local userCustomData_tgt = _G.CustomTagsConfig and _G.CustomTagsConfig[tostring(targetPlayer.UserId)]
    
    -- LÓGICA MESTRA
    local isForcedCustom = false
    if userCustomData_tgt then
        if userCustomData_tgt.IsActive == true or userCustomData_tgt.IsActive == "true" then
            isForcedCustom = true
        elseif userCustomData_tgt.Equipped and userCustomData_tgt.Equipped ~= "" then
            rankName_tgt = userCustomData_tgt.Equipped
        end
    end

    if targetPlayer == game.Players.LocalPlayer then
        if isForcedCustom then 
            _G.EquippedTag = "Custom" 
        elseif _G.EquippedTag == "Custom" and not userCustomData_tgt then
            _G.EquippedTag = nil
        end
        rankName_tgt = _G.EquippedTag or rankName_tgt
    else
        if isForcedCustom then
            rankName_tgt = "Custom"
        elseif _G.PresenceTags and _G.PresenceTags[targetPlayer.UserId] then
            rankName_tgt = _G.PresenceTags[targetPlayer.UserId]
        end
    end

    local count_tgt = 0
    for _, v in ipairs(head_tgt:GetChildren()) do
        if v.Name == "S7x_ProTag" and v:IsA("BillboardGui") then
            count_tgt = count_tgt + 1
            if count_tgt > 1 then v:Destroy() end
        end
    end

    local existingTag_tgt = head_tgt:FindFirstChild("S7x_ProTag")
    local textLabel_tgt = nil

    if not existingTag_tgt then
        existingTag_tgt = Instance.new("BillboardGui")
        existingTag_tgt.Name = "S7x_ProTag"
        existingTag_tgt.Adornee = head_tgt
        existingTag_tgt.Size = UDim2.new(3.5, 0, 0.8, 0) 
        existingTag_tgt.StudsOffset = Vector3.new(0, 4.0, 0) 
        existingTag_tgt.AlwaysOnTop = true
        existingTag_tgt.MaxDistance = 100 
        existingTag_tgt.Enabled = _G.S7xTagVisible
        existingTag_tgt.Parent = head_tgt

        textLabel_tgt = Instance.new("TextLabel", existingTag_tgt)
        textLabel_tgt.Size = UDim2.new(1, 0, 1, 0)
        textLabel_tgt.BackgroundTransparency = 1
        textLabel_tgt.Font = Enum.Font.GothamBlack 
        textLabel_tgt.TextScaled = true
        textLabel_tgt.TextStrokeTransparency = 0
        
        local grad_tgt = Instance.new("UIGradient", textLabel_tgt)
        grad_tgt.Name = "ShineGradient"
        grad_tgt.Rotation = 45 
        
        game:GetService("TweenService"):Create(existingTag_tgt, TweenInfo.new(1.2, Enum.EasingStyle.Elastic, Enum.EasingDirection.Out), {StudsOffset = Vector3.new(0, 3.2, 0)}):Play()
        local textConstraint_tgt = Instance.new("UITextSizeConstraint", textLabel_tgt)
        textConstraint_tgt.MaxTextSize = (rankName_tgt == "Developer") and 9 or 12
    else
        textLabel_tgt = existingTag_tgt:FindFirstChildOfClass("TextLabel")
        existingTag_tgt.Enabled = _G.S7xTagVisible 
    end

    if not textLabel_tgt then return end

    if SpecialTags[targetPlayer.UserId] and SpecialTags[targetPlayer.UserId].Head ~= head_tgt then
        pcall(function() SpecialTags[targetPlayer.UserId].Label.Parent:Destroy() end)
    end

    local displayName_tgt = rankName_tgt
    if rankName_tgt == "Custom" then
        if userCustomData_tgt and userCustomData_tgt.CustomName and userCustomData_tgt.CustomName ~= "" then 
            displayName_tgt = userCustomData_tgt.CustomName -- Preserva maiúsculas e minúsculas reais
        else
            displayName_tgt = "EDITED"
        end
    else
        local configForName_tgt = _G.CustomTagsConfig and _G.CustomTagsConfig[rankName_tgt]
        if configForName_tgt and configForName_tgt.CustomName and configForName_tgt.CustomName ~= "" then
            displayName_tgt = configForName_tgt.CustomName -- Preserva maiúsculas e minúsculas reais
        else
            displayName_tgt = string.upper(rankName_tgt) -- Força Upper apenas nos nomes padrão (Ex: OWNER)
        end
    end

    textLabel_tgt.Text = displayName_tgt
    SpecialTags[targetPlayer.UserId] = {Label = textLabel_tgt, Rank = rankName_tgt, Head = head_tgt}
end

