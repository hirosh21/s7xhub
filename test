S7xSetHardwareMute = function(isMuted)
    _G.S7xIsMuted = isMuted
    
    -- Camada 1: Mute API
    pcall(function() 
        vc_svc = game:GetService("VoiceChatService")
        if vc_svc then vc_svc:SetMicMuted(isMuted) end
    end)
    
    -- Camada 2: Bloqueio de Servidor Vivox
    pcall(function()
        vc_internal = game:GetService("VoiceChatInternal")
        if vc_internal then vc_internal:PublishPause(isMuted) end
    end)
    
    -- Camada 3: Desconexão de Hardware (Gera o "Desconectado" no Menu)
    pcall(function()
        for _, v in ipairs(game:GetDescendants()) do
            if v:IsA("AudioDeviceInput") then
                -- Desliga fisicamente a captura de áudio da sua máquina para o Roblox
                v.Active = not isMuted 
            end
        end
    end)
    
    -- Atualização Visual do Painel M7/S7X
    if S7xStatusText then
        if _G.S7xIsMuted then
            S7xStatusText.Text = _G.S7xPTT and "HOLD TO UNMUTE" or (_G.S7xPTM and "MUTED" or "MIC OFF")
            S7xStatusText.TextColor3 = Color3.fromRGB(255, 68, 68) 
            if S7xStatusIcon then S7xStatusIcon.ImageColor3 = Color3.fromRGB(255, 68, 68) end
            if S7xSideLine then S7xSideLine.BackgroundColor3 = Color3.fromRGB(255, 68, 68) end
            if S7xMainStroke then S7xMainStroke.Color = Color3.fromRGB(40, 40, 45) end
        else
            S7xStatusText.Text = "MIC ACTIVE (SPEAKING...)"
            S7xStatusText.TextColor3 = Color3.fromRGB(170, 0, 255) 
            if S7xStatusIcon then S7xStatusIcon.ImageColor3 = Color3.fromRGB(170, 0, 255) end
            if S7xSideLine then S7xSideLine.BackgroundColor3 = Color3.fromRGB(170, 0, 255) end
            if S7xSideText then S7xSideText.Text = "MIC ACTIVE" end
            if S7xMainStroke then S7xMainStroke.Color = Color3.fromRGB(170, 0, 255) end
            _G.S7xMuteTimer = 0 
        end
    end
end

