-- Motor de Busca de Cargos Isolado (Assíncrono)
local function fetchPlayerRole(plr)
    if roleCache[plr.UserId] then return end
    
    roleCache[plr.UserId] = {role = "Loading...", color = Color3.fromRGB(255, 255, 255), hex = "#FFFFFF"}
    
    task.spawn(function()
        -- Busca se é amigo e salva na memória (Otimizado via pcall para não dar erro)
        pcall(function()
            friendCache[plr.UserId] = LocalPlayer:IsFriendsWith(plr.UserId)
        end)

        local success, role = pcall(function() return plr:GetRoleInGroup(34157675) end)
        if success and role and role ~= "Guest" then
            local checkR = string.lower(role)
            if checkR == "member" or checkR == "members" then
                roleCache[plr.UserId] = {role = "User", color = Color3.fromRGB(255, 255, 255), hex = "#FFFFFF"}
                return
            end
            
            local c = Color3.fromRGB(255, 255, 255)
            local h = "#FFFFFF"
            
            if string.find(checkR, "influencer") then 
                c = Color3.fromRGB(255, 20, 147); h = "#FF1493"
            elseif string.find(checkR, "contributor") then 
                c = Color3.fromRGB(255, 100, 0); h = "#FF6400"
            elseif string.find(checkR, "marketing") or string.find(checkR, "social mod") or string.find(checkR, "helper") or string.find(checkR, "supervisor") or string.find(checkR, "manager") or string.find(checkR, "developer") or string.find(checkR, "owner") then 
                c = Color3.fromRGB(255, 0, 0); h = "#FF0000"
            end
            roleCache[plr.UserId] = {role = role, color = c, hex = h}
        else
            roleCache[plr.UserId] = {role = "User", color = Color3.fromRGB(255, 255, 255), hex = "#FFFFFF"}
        end
    end)
end

