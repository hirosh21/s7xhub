local function setToggleState(btn, isEnabled)
    local bg = btn:FindFirstChild("ToggleBG")
    local knob = bg and bg:FindFirstChild("ToggleKnob")
    local glow = knob and knob:FindFirstChild("Glow")
    local strk = btn:FindFirstChildOfClass("UIStroke")
    local bgStrk = bg and bg:FindFirstChildOfClass("UIStroke")
    
    if bg and knob then
        if isEnabled then
            SafeTween(bg, 0.4, {BackgroundColor3 = Color3.fromRGB(170, 0, 255)})
            SafeTween(bgStrk, 0.4, {Color = Color3.fromRGB(200, 100, 255)})
            SafeTween(knob, 0.4, {Position = UDim2.new(1, -14, 0.5, -6), BackgroundColor3 = Color3.fromRGB(255, 255, 255)}, Enum.EasingStyle.Back)
            if glow then SafeTween(glow, 0.4, {ImageTransparency = 0.2}) end
            SafeTween(btn, 0.4, {BackgroundColor3 = Color3.fromRGB(50, 20, 90)})
            if strk then SafeTween(strk, 0.3, {Color = Color3.fromRGB(200, 50, 255), Thickness = 1.5}) end
        else
            SafeTween(bg, 0.3, {BackgroundColor3 = Color3.fromRGB(15, 12, 18)})
            SafeTween(bgStrk, 0.3, {Color = Color3.fromRGB(60, 30, 80)})
            SafeTween(knob, 0.3, {Position = UDim2.new(0, 2, 0.5, -6), BackgroundColor3 = Color3.fromRGB(150, 150, 160)}, Enum.EasingStyle.Back)
            if glow then SafeTween(glow, 0.3, {ImageTransparency = 1}) end
            SafeTween(btn, 0.3, {BackgroundColor3 = Color3.fromRGB(25, 25, 30)})
            if strk then SafeTween(strk, 0.3, {Color = Color3.fromRGB(80, 40, 120), Thickness = 1.2}) end
        end
    end
end

