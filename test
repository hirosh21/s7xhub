_G.SyncEmoteEnabled = false
_G.ActiveSyncTracks = {}

GUI.CopyAnimBtn.MouseButton1Click:Connect(function()
    _G.SyncEmoteEnabled = not _G.SyncEmoteEnabled
    pcall(function() if setToggleState then setToggleState(GUI.CopyAnimBtn, _G.SyncEmoteEnabled) end end)
    
    -- Limpa as animações se desligar a opção
    if not _G.SyncEmoteEnabled then
        for id, track in pairs(_G.ActiveSyncTracks) do
            if track then track:Stop() end
        end
        _G.ActiveSyncTracks = {}
    end
end)

-- Loop de Monitoramento Furtivo (Alta Frequência)
task.spawn(function()
    while task.wait(0.1) do
        if _G.SyncEmoteEnabled and spectatingPlayer and spectatingPlayer.Character then -- Usa a variável de alvo do hub [cite: 534]
            pcall(function()
                local myChar = game.Players.LocalPlayer.Character
                local myAnim = myChar and myChar:FindFirstChildOfClass("Humanoid") and myChar.Humanoid:FindFirstChildOfClass("Animator")
                
                local tChar = spectatingPlayer.Character
                local tAnim = tChar and tChar:FindFirstChildOfClass("Humanoid") and tChar.Humanoid:FindFirstChildOfClass("Animator")
                
                if myAnim and tAnim then
                    local tTracks = tAnim:GetPlayingAnimationTracks()
                    local currentlyPlaying = {}
                    
                    for _, track in ipairs(tTracks) do
                        if track.Animation and track.Animation.AnimationId then
                            local id = track.Animation.AnimationId
                            currentlyPlaying[id] = true
                            
                            -- Sincroniza apenas se for uma nova animação de ação/emote
                            if not _G.ActiveSyncTracks[id] then
                                -- Filtro Profissional: Ignora animações de movimento (andar/correr)
                                if track.Priority == Enum.AnimationPriority.Action or track.Priority == Enum.AnimationPriority.Action2 or track.Priority == Enum.AnimationPriority.Action3 then
                                    local newAnim = Instance.new("Animation")
                                    newAnim.AnimationId = id
                                    local newTrack = myAnim:LoadAnimation(newAnim)
                                    newTrack.Priority = track.Priority
                                    newTrack:Play()
                                    newTrack:AdjustSpeed(track.Speed) -- Sincroniza a velocidade exata
                                    _G.ActiveSyncTracks[id] = newTrack
                                end
                            end
                        end
                    end
                    
                    -- Para as nossas tracks se o alvo parar de fazer o emote
                    for id, myTrack in pairs(_G.ActiveSyncTracks) do
                        if not currentlyPlaying[id] then
                            myTrack:Stop()
                            _G.ActiveSyncTracks[id] = nil
                        end
                    end
                end
            end)
        end
    end
end)

