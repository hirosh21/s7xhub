RunService.RenderStepped:Connect(function()
    if flyEnabled and flyBV and flyBG and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        local hum = player.Character:FindFirstChild("Humanoid")
        local camCF = camera.CoordinateFrame
        
        ctrl = {f = 0, b = 0, l = 0, r = 0}
        
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then ctrl.f = 1 end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then ctrl.b = -1 end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then ctrl.l = -1 end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then ctrl.r = 1 end
        
        if isMobile and hum and hum.MoveDirection.Magnitude > 0 then
            local rel = camCF:VectorToObjectSpace(hum.MoveDirection)
            if rel.Z < -0.2 then ctrl.f = 1 end
            if rel.Z > 0.2 then ctrl.b = -1 end
            if rel.X < -0.2 then ctrl.l = -1 end
            if rel.X > 0.2 then ctrl.r = 1 end
        end

        if hum then
            if ctrl.f == 1 then 
                PlayFlyAnimation(hum, 10714177846) 
            elseif ctrl.b == -1 or ctrl.l == -1 or ctrl.r == 1 then 
                PlayFlyAnimation(hum, 10147823318) 
            else 
                PlayFlyAnimation(hum, 10714347256) 
            end
        end

        if ctrl.l + ctrl.r ~= 0 or ctrl.f + ctrl.b ~= 0 then
            flySpeed = flySpeed + flySpeedValue * 0.10
            if flySpeed > flySpeedValue then flySpeed = flySpeedValue end
        elseif not (ctrl.l + ctrl.r ~= 0 or ctrl.f + ctrl.b ~= 0) and flySpeed ~= 0 then
            flySpeed = flySpeed - flySpeedValue * 0.10
            if flySpeed < 0 then flySpeed = 0 end
        end
        
        if (ctrl.l + ctrl.r) ~= 0 or (ctrl.f + ctrl.b) ~= 0 then
            flyBV.velocity = ((camCF.lookVector * (ctrl.f+ctrl.b)) + ((camCF * CFrame.new(ctrl.l+ctrl.r,(ctrl.f+ctrl.b)*.2,0).p) - camCF.p)) * flySpeed
            lastctrl = {f = ctrl.f, b = ctrl.b, l = ctrl.l, r = ctrl.r}
        elseif (ctrl.l + ctrl.r) == 0 and (ctrl.f + ctrl.b) == 0 and flySpeed ~= 0 then
            flyBV.velocity = ((camCF.lookVector * (lastctrl.f+lastctrl.b)) + ((camCF * CFrame.new(lastctrl.l+lastctrl.r,(lastctrl.f+lastctrl.b)*.2,0).p) - camCF.p)) * flySpeed
        else
            flyBV.velocity = Vector3.new(0, 0.1, 0)
        end
        
        flyBG.cframe = camCF * CFrame.Angles(-math_rad((ctrl.f+ctrl.b) * 50 * flySpeed / flySpeedValue), 0, 0)
    end
end)
