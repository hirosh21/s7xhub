-- Toggle Panel (Com Memória de Posição e Animação Dinâmica)
local function togglePanel()
    panelOpen = not panelOpen
    if panelOpen then
        -- Calcula o centro da janela baseando-se em onde ela estava
        local shrinkPos = UDim2.new(panelTargetPos.X.Scale, panelTargetPos.X.Offset + (panelTargetSize.X.Offset / 2), panelTargetPos.Y.Scale, panelTargetPos.Y.Offset + (panelTargetSize.Y.Offset / 2))
        
        GUI.MainFrame.Size = UDim2.new(0, 0, 0, 0)
        GUI.MainFrame.Position = shrinkPos
        GUI.MainFrame.Visible = true
        
        pcall(function()
            game:GetService("TweenService"):Create(GUI.MainFrame, TweenInfo.new(0.5, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out), {
                Size = panelTargetSize,
                Position = panelTargetPos
            }):Play()
        end)
    else
        -- O PULO DO GATO: Salva a posição e o tamanho atual exato antes de fechar
        panelTargetPos = GUI.MainFrame.Position
        panelTargetSize = GUI.MainFrame.Size
        
        pcall(function()
            -- Encolhe a janela para o próprio centro, onde quer que ela esteja
            local shrinkPos = UDim2.new(panelTargetPos.X.Scale, panelTargetPos.X.Offset + (panelTargetSize.X.Offset / 2), panelTargetPos.Y.Scale, panelTargetPos.Y.Offset + (panelTargetSize.Y.Offset / 2))
            
            local tween = game:GetService("TweenService"):Create(GUI.MainFrame, TweenInfo.new(0.4, Enum.EasingStyle.Exponential, Enum.EasingDirection.In), {
                Size = UDim2.new(0, 0, 0, 0),
                Position = shrinkPos
            })
            tween:Play()
            task.spawn(function()
                tween.Completed:Wait()
                if not panelOpen then GUI.MainFrame.Visible = false end
            end)
        end)
    end
end

