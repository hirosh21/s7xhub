local flashbackEnabled = false
local isRewinding = false
local flashbackHistory = {}

GUI.FlashbackBtn.MouseButton1Click:Connect(function()
    flashbackEnabled = not flashbackEnabled
    setToggleState(GUI.FlashbackBtn, flashbackEnabled)
    if not flashbackEnabled then flashbackHistory = {} end
end)

RunService.Heartbeat:Connect(function()
    if flashbackEnabled and not isRewinding and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        local hrp = player.Character.HumanoidRootPart
        table.insert(flashbackHistory, 1, {cf = hrp.CFrame, vel = hrp.Velocity})
        if #flashbackHistory > 150 then
            table.remove(flashbackHistory, #flashbackHistory)
        end
    end
end)

local function triggerFlashback()
    if not flashbackEnabled or isRewinding or #flashbackHistory == 0 then return end
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    isRewinding = true
    
    local originalCollisions = {}
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then 
            originalCollisions[part] = part.CanCollide
            part.CanCollide = false 
        end
    end
    
    for i = 1, #flashbackHistory do
        if not hrp or not hrp.Parent then break end
        hrp.CFrame = flashbackHistory[i].cf
        hrp.Velocity = flashbackHistory[i].vel
        RunService.RenderStepped:Wait()
    end
    
    if char and char.Parent then
        for part, state in pairs(originalCollisions) do
            if part and part.Parent then part.CanCollide = state end
        end
    end
    
    flashbackHistory = {}
    isRewinding = false
end

