local function togglePTarget()
    if currentPTarget then
        -- Destrava
        currentPTarget = nil
        GUI.FloatPBtn.Text = "P\nLOCK"
        GUI.FloatPBtn.BackgroundColor3 = Color3.fromRGB(170, 0, 255)
        GUI.RemoteStatusText.Text = "Procurando alvo..."
        GUI.RemoteStatusText.TextColor3 = Color3.fromRGB(200, 200, 200)
    else
        -- Trava no jogador mais próximo do mouse
        local mouse = game.Players.LocalPlayer:GetMouse()
        local mPos = mouse.Hit.Position
        local minDist = math.huge
        
        for _, p in ipairs(game:GetService("Players"):GetPlayers()) do
            if p ~= game.Players.LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local dist = (p.Character.HumanoidRootPart.Position - mPos).Magnitude
                if dist < minDist then 
                    minDist = dist
                    currentPTarget = p 
                end
            end
        end
        
        if currentPTarget then 
            GUI.FloatPBtn.Text = "P\nUNLK"
            GUI.FloatPBtn.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
            GUI.RemoteStatusText.Text = "LOCKED: @" .. currentPTarget.Name
            GUI.RemoteStatusText.TextColor3 = Color3.fromRGB(255, 50, 50)
        end
    end
end

