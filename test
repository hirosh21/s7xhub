local function createTabBtn(text, order)
    local btn = Instance.new("TextButton", GUI.TabMenu)
    btn.Size = UDim2.new(0.9, 0, 0, 32)
    btn.Text = text
    btn.BackgroundColor3 = Color3.fromRGB(170, 0, 255)
    btn.BackgroundTransparency = 1 
    btn.TextColor3 = Color3.fromRGB(200, 200, 210) 
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 11
    btn.LayoutOrder = order
    btn.AutoButtonColor = false
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    
    local indicator = Instance.new("Frame", btn)
    indicator.Name = "Indicator"
    indicator.Size = UDim2.new(0, 0, 0.6, 0)
    indicator.Position = UDim2.new(0, 0, 0.2, 0)
    indicator.BackgroundColor3 = Color3.fromRGB(200, 100, 255)
    indicator.BorderSizePixel = 0
    Instance.new("UICorner", indicator).CornerRadius = UDim.new(1, 0)

    btn.MouseEnter:Connect(function()
        if btn.BackgroundTransparency == 1 then
            pcall(function()
                game:GetService("TweenService"):Create(btn, TweenInfo.new(0.3), {TextColor3 = Color3.fromRGB(255, 255, 255), BackgroundTransparency = 0.9}):Play()
                game:GetService("TweenService"):Create(indicator, TweenInfo.new(0.3, Enum.EasingStyle.Back), {Size = UDim2.new(0, 4, 0.6, 0)}):Play()
            end)
        end
    end)
    
    btn.MouseLeave:Connect(function()
        if btn.BackgroundTransparency > 0.1 then 
            pcall(function()
                game:GetService("TweenService"):Create(btn, TweenInfo.new(0.3), {TextColor3 = Color3.fromRGB(200, 200, 210), BackgroundTransparency = 1}):Play()
                game:GetService("TweenService"):Create(indicator, TweenInfo.new(0.3), {Size = UDim2.new(0, 0, 0.6, 0)}):Play()
            end)
        end
    end)
    
    return btn
end

