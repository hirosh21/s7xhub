-- Função Global de Retorno no Tempo (Linkada à Hotkey do PC e ao Botão Mobile)
triggerFlashback = function() 
    if not _G.S7xFlashback.Enabled or _G.S7xFlashback.Rewinding or #_G.S7xFlashback.History == 0 then return end
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    _G.S7xFlashback.Rewinding = true
    
    -- Desliga colisões para não travar nas paredes enquanto volta
    local originalCollisions = {}
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then 
            originalCollisions[part] = part.CanCollide
            part.CanCollide = false 
        end
    end
    
    -- Retrocesso Suave (RenderStepped)
    for i = 1, #_G.S7xFlashback.History do
        if not hrp or not hrp.Parent then break end
        hrp.CFrame = _G.S7xFlashback.History[i].cf
        hrp.Velocity = _G.S7xFlashback.History[i].vel
        game:GetService("RunService").RenderStepped:Wait()
    end
    
    -- Restaura colisões normais
    if char and char.Parent then
        for part, state in pairs(originalCollisions) do
            if part and part.Parent then part.CanCollide = state end
        end
    end
    
    _G.S7xFlashback.History = {}
    _G.S7xFlashback.Rewinding = false
end

