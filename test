do
    _G.AutoParryBB = false
    _G.ParryDistance = 25 -- Distância padrão segura

    -- 1. Cria o Botão na Aba MAIN (Substitua GUI.MainFrame pelo container correto se necessário)
    local apBtn = createToggleButton("AUTO PARRY", GUI.MainCombateContainer or GUI.MainFrame)
    addKeybindBox(apBtn, "AutoParry")

    -- 2. Barra de Deslizar (Slider) para ajustar a distância do Parry (Máximo 150)
    addMiniSlider(apBtn, _G.ParryDistance, 150, function(val)
        _G.ParryDistance = math.max(10, val) -- Mínimo de 10 para não bugar
    end)

    apBtn.MouseButton1Click:Connect(function()
        _G.AutoParryBB = not _G.AutoParryBB
        if setToggleState then setToggleState(apBtn, _G.AutoParryBB) end
    end)

    -- 3. O CÉREBRO DO PARRY (Bypass Anti-Cheat via Virtual Input)
    local runService = game:GetService("RunService")
    local vim = game:GetService("VirtualInputManager")

    -- Função que simula o Humano batendo na bola e ativando a Habilidade
    local function triggerParry()
        -- Simula o CLIQUE ESQUERDO DO MOUSE (Defesa padrão do Blade Ball)
        vim:SendMouseButtonEvent(0, 0, 0, true, game, 0)
        task.delay(0.05, function()
            vim:SendMouseButtonEvent(0, 0, 0, false, game, 0)
        end)
        
        -- Simula a TECLA Q (Ativa a Habilidade Especial quando a bola estiver carregada)
        vim:SendKeyEvent(true, Enum.KeyCode.Q, false, game)
        task.delay(0.05, function()
            vim:SendKeyEvent(false, Enum.KeyCode.Q, false, game)
        end)
    end

    -- Função cirúrgica para achar a bola real do jogo
    local function getBladeBall()
        -- O Blade Ball geralmente guarda as bolas numa pasta chamada "Balls"
        local ballsFolder = workspace:FindFirstChild("Balls")
        if ballsFolder then
            for _, ball in ipairs(ballsFolder:GetChildren()) do
                if ball:IsA("BasePart") then
                    return ball
                end
            end
        end
        return nil
    end

    -- Loop de cálculo (Roda na velocidade do seu FPS)
    runService.Heartbeat:Connect(function()
        if not _G.AutoParryBB then return end
        
        local char = game.Players.LocalPlayer.Character
        if not char or not char:FindFirstChild("HumanoidRootPart") then return end
        
        local hrp = char.HumanoidRootPart
        local ball = getBladeBall()
        
        if ball then
            local dist = (ball.Position - hrp.Position).Magnitude
            local ballVel = ball.AssemblyLinearVelocity
            
            -- FÍSICA AVANÇADA (Dot Product): Verifica se a bola está voando NA SUA DIREÇÃO
            local dirToPlayer = (hrp.Position - ball.Position).Unit
            local approachSpeed = ballVel:Dot(dirToPlayer)
            
            -- LÓGICA 1: Bate pela Distância do Slider
            -- Se a bola chegou na distância do seu slider E está vindo na sua direção
            if dist <= _G.ParryDistance and approachSpeed > 5 then
                triggerParry()
            end
            
            -- LÓGICA 2: Defesa de Emergência (Bola Carregada/Velocidade da Luz)
            -- Se a bola estiver absurdamente rápida, o slider normal falha. 
            -- Aqui nós calculamos o TEMPO de impacto. Se for bater em menos de 0.25 segundos, ele defende e solta a Habilidade!
            if approachSpeed > 60 then
                local timeToImpact = dist / approachSpeed
                if timeToImpact < 0.25 then
                    triggerParry()
                end
            end
        end
    end)
end

