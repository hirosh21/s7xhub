task.spawn(function()
    pcall(function()
        local RS = game:GetService("ReplicatedStorage")
        
        -- Função interna para não gastar variáveis locais do script inteiro
        local function blindarModulo(nomeDoModulo)
            local modulo = RS:FindFirstChild(nomeDoModulo, true)
            if not modulo or not modulo:IsA("ModuleScript") then return end
            
            local sucesso, req = pcall(require, modulo)
            if not sucesso or type(req) ~= "table" then return end
            
            -- Libera a tabela para edição caso o executor exija
            if setreadonly then pcall(setreadonly, req, false) end
            
            for chave, funcao in pairs(req) do
                if type(funcao) == "function" then
                    if hookfunction then
                        -- Interceptação profunda na memória (Bypass Definitivo)
                        local velhaFuncao; velhaFuncao = hookfunction(funcao, function(...)
                            local s, r = pcall(velhaFuncao, ...)
                            if not s then return nil end
                            return r
                        end)
                    else
                        -- Fallback para executors mais simples
                        local velhaFuncao = funcao
                        req[chave] = function(...)
                            local s, r = pcall(velhaFuncao, ...)
                            if not s then return nil end
                            return r
                        end
                    end
                end
            end
            
            -- Bloqueia a tabela novamente por segurança
            if setreadonly then pcall(setreadonly, req, true) end
        end
        
        -- Aplica a blindagem cirúrgica nos módulos que estão floodando o console
        blindarModulo("EffectsController")
