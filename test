-- Intercepta e destrói pacotes de denúncia e telemetria ANTES de saírem do seu PC.
pcall(function()
    if not _G.VCHooked and hookmetamethod then
        _G.VCHooked = true
        
        -- Usamos newcclosure para fingir que o hook é código C nativo do Roblox (Indetectável)
        local old_namecall
        old_namecall = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
            -- Se o AntiBan estiver ligado, o escaneamento começa
            if _G.AntiBanVcEnabled and not checkcaller() then
                local method = getnamecallmethod()
                local mStr = tostring(method)
                
                -- A Lista Negra: Destrói qualquer pacote de Analytics ou Report de Voz
                if mStr == "ReportUser" 
                or mStr == "ReportAbuse"
                or mStr == "SendVoiceAnalytics" 
                or mStr == "SendRobloxTelemetry"
                or mStr == "SendEventToServer" 
                or mStr == "Report" then
                    -- Retorna vazio. O jogo acha que enviou o reporte, mas ele caiu num buraco negro.
                    return 
                end
            end
            
            return old_namecall(self, ...)
        end))
    end
end)

