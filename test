_G.S7xClearAllShaders = function()
    local lighting = game:GetService("Lighting")
    for _, v in ipairs(lighting:GetChildren()) do
        if v:IsA("PostEffect") or v:IsA("Sky") or v:IsA("Atmosphere") or v:IsA("ColorCorrectionEffect") or v:IsA("BloomEffect") or v:IsA("BlurEffect") or v:IsA("SunRaysEffect") or v:IsA("DepthOfFieldEffect") then
            v:Destroy()
        end
    end
    lighting.ClockTime = 14
    lighting.Brightness = 2
    lighting.ExposureCompensation = 0
    if workspace:FindFirstChild("Terrain") then
        workspace.Terrain.WaterReflectance = 1
        workspace.Terrain.WaterTransparency = 0.3
        workspace.Terrain.WaterWaveSpeed = 10
        workspace.Terrain.WaterWaveSize = 0.15
    end
end

_G.S7xRemoveFakeSky = function()
    for _,obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("MeshPart") or obj:IsA("Part") then
            if obj.Name:lower():find("sky") or obj.Name:lower():find("dome") then
                obj:Destroy()
            end
        end
    end
end

_G.S7xCacheGround = function()
    for _,v in pairs(workspace:GetDescendants()) do
        if v:IsA("Part") then
            if v.Material == Enum.Material.Concrete or v.Material == Enum.Material.Asphalt or v.Material == Enum.Material.Slate or v.Material == Enum.Material.Pavement then
                table.insert(_G.S7xCachedGround, v)
            end
        end
    end
end

_G.S7xWetGround = function()
    for _,v in pairs(_G.S7xCachedGround) do
        if v and v.Parent then
            v.Material = Enum.Material.SmoothPlastic
            v.Reflectance = 0.4
        end
    end
end

_G.S7xUltraWater = function()
    local terrain = workspace.Terrain
    if terrain then
        terrain.WaterTransparency = 0.25
        terrain.WaterReflectance = 0.8
        terrain.WaterWaveSize = 0.16
        terrain.WaterWaveSpeed = 14
    end
end

