-- 2. P2P PING: Gatilho instantâneo que avisa a engine do Roblox
SendP2PPing = function()
    pcall(function()
        local char_ping = game.Players.LocalPlayer.Character
        if not char_ping then return end
        local hum_ping = char_ping:FindFirstChild("Humanoid")
        local animator_ping = hum_ping and hum_ping:FindFirstChild("Animator")
        
        if animator_ping then
            local targetId_ping = hum_ping.RigType == Enum.HumanoidRigType.R6 and SIGNAL_ID_R6 or SIGNAL_ID_R15
            local syncAnim_ping = Instance.new("Animation")
            syncAnim_ping.AnimationId = targetId_ping
            local track_ping = animator_ping:LoadAnimation(syncAnim_ping)
            track_ping.Priority = Enum.AnimationPriority.Core
            track_ping:Play(0, 0.0001, 0)
            task.delay(0.2, function() track_ping:Stop() end)
        end
    end)
end

SyncServerPresence = function()
    if not _G.S7xTagVisible then return end
    pcall(function()
        -- Busca no Supabase apenas os jogadores que estão no MESMO SERVIDOR (Filtro JobId)
        local res_sync = _G.S7xRequest("/presence?payload->>JobId=eq." .. tostring(game.JobId) .. "&select=*", "GET")
        if res_sync and res_sync ~= "[]" and res_sync ~= "null" then
            local decoded_sync = game:GetService("HttpService"):JSONDecode(res_sync)
            if type(decoded_sync) == "table" then
                local currentTime_sync = os.time()
                for _, row in ipairs(decoded_sync) do
                    local uid_sync = tonumber(row.id)
                    local data = row.payload
                    
                    if uid_sync and data and uid_sync ~= game.Players.LocalPlayer.UserId then
                        local targetPlr_sync = game:GetService("Players"):GetPlayerByUserId(uid_sync)
                        -- Tolerância de 45 segundos para manter a tag online mesmo com lag de rede
                        if targetPlr_sync and data.Time and (currentTime_sync - data.Time <= 45) then 
                            _G.PresenceTags[uid_sync] = data.Tag 
                            _G.PresenceAuras[uid_sync] = data.Aura 
                            
                            if not S7xUsers[uid_sync] then
                                S7xUsers[uid_sync] = true
                            end
                            
                            -- Renderiza na sua tela a Tag e a Aura do outro jogador
                            task.spawn(function()
                                if ApplyOrUpdateTag then ApplyOrUpdateTag(targetPlr_sync) end
                                if ApplyS7xAura then ApplyS7xAura(targetPlr_sync) end
                            end)
                            
                        elseif S7xUsers[uid_sync] then
                            S7xUsers[uid_sync] = nil
                            _G.PresenceTags[uid_sync] = nil
                            _G.PresenceAuras[uid_sync] = nil
                            if SpecialTags[uid_sync] then 
                                pcall(function() SpecialTags[uid_sync].Label.Parent:Destroy() end)
                                SpecialTags[uid_sync] = nil 
                            end
                        end
                    end
                end
            end
        end
    end)
end

-- 4. ESCUTA P2P: O "Ouvido" que capta o grito dos outros instantaneamente
MonitorP2PPing = function(p, char)
    local hum_mon = char:WaitForChild("Humanoid", 5)
    local animator_mon = hum_mon and hum_mon:WaitForChild("Animator", 5)
    if animator_mon then
        animator_mon.AnimationPlayed:Connect(function(track)
            local animId_mon = track.Animation and track.Animation.AnimationId or ""
            if animId_mon == SIGNAL_ID_R6 or animId_mon == SIGNAL_ID_R15 then
                -- ALGUÉM ABRIU O PAINEL! Baixa a tag dele do Supabase na mesma hora!
                task.spawn(SyncServerPresence)
            end
        end)
    end
end

