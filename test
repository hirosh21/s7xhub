        -- Calcula o centro da janela baseando-se em onde ela estava
        local shrinkPos = UDim2.new(panelTargetPos.X.Scale, panelTargetPos.X.Offset + (panelTargetSize.X.Offset / 2), panelTargetPos.Y.Scale, panelTargetPos.Y.Offset + (panelTargetSize.Y.Offset / 2))
        
