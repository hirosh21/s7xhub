-- Interpretador Universal de Cores
S7xParseColor = function(c, defaultColor)
    if typeof(c) == "Color3" then return c end
    if type(c) == "string" then
        c = string.gsub(c, " ", "") 
        if string.sub(c, 1, 1) == "#" then
            local s, res = pcall(function() return Color3.fromHex(c) end)
            if s then return res end
        end
        local r, g, b = string.match(c, "(%d+)[^%d]+(%d+)[^%d]+(%d+)")
        if r and g and b then 
            return Color3.fromRGB(tonumber(r), tonumber(g), tonumber(b)) 
        end
    end
    return defaultColor or Color3.fromRGB(255, 255, 255)
end

-- Limpa loops fantasmas
if _G.TagRenderConnection then _G.TagRenderConnection:Disconnect() end

_G.TagRenderConnection = game:GetService("RunService").RenderStepped:Connect(function()
    if not _G.S7xTagVisible then return end
    
    local t = tick()
    local hue = (t % 5) / 5
    local metallicOffset = (t * 0.7) % 2 - 1

    for userId, data in pairs(SpecialTags) do
        local head = data.Head
        if not head or not head.Parent or not head:IsDescendantOf(workspace) or (head.Parent:FindFirstChild("Humanoid") and head.Parent.Humanoid.Health <= 0) then
            pcall(function() if data.Label and data.Label.Parent then data.Label.Parent:Destroy() end end)
            SpecialTags[userId] = nil
            continue
        end
        
        local lbl = data.Label
        local rank = data.Rank
        local grad = lbl:FindFirstChild("ShineGradient") or Instance.new("UIGradient", lbl)

        pcall(function()
            local function ApplyMetallic(baseColor)
                grad.Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0, baseColor),
                    ColorSequenceKeypoint.new(0.40, baseColor),
                    ColorSequenceKeypoint.new(0.5, Color3.fromRGB(255, 255, 255)),
                    ColorSequenceKeypoint.new(0.60, baseColor),
                    ColorSequenceKeypoint.new(1, baseColor)
                })
                grad.Offset = Vector2.new(metallicOffset, 0)
                lbl.TextColor3 = Color3.fromRGB(255, 255, 255)
            end
            
            local function ApplySolid(color)
                grad.Color = ColorSequence.new(Color3.fromRGB(255, 255, 255))
                grad.Offset = Vector2.new(0, 0)
                lbl.TextColor3 = color
            end

            -- Busca configuração
            local customConf = nil
            if rank == "Custom" then
                customConf = _G.CustomTagsConfig[tostring(userId)]
            else
                customConf = _G.CustomTagsConfig[rank]
            end
            
            -- LÓGICA BLINDADA PARA TAGS EDITADAS PELO DISCORD
            if customConf then
                local cMain = S7xParseColor(customConf.Color, Color3.fromRGB(255, 255, 255))
                local cStroke = S7xParseColor(customConf.StrokeColor, Color3.fromRGB(0, 0, 0))
                local transpStroke = tonumber(customConf.StrokeTransparency) or 0
                
                if customConf.Effect == "Metallic" or customConf.Effect == "Metalico" then
                    ApplyMetallic(cMain)
                    lbl.TextStrokeColor3 = cStroke
                    lbl.TextStrokeTransparency = transpStroke
                elseif customConf.Effect == "Duo-chrome" then
                    local c1 = S7xParseColor(customConf.Color1, Color3.fromRGB(255, 240, 255))
                    local c2 = S7xParseColor(customConf.Color2, Color3.fromRGB(240, 255, 255))
                    
                    grad.Color = ColorSequence.new({
                        ColorSequenceKeypoint.new(0, c1),
                        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(255, 255, 255)),
                        ColorSequenceKeypoint.new(1, c2)
                    })
                    grad.Offset = Vector2.new(metallicOffset * 0.8, 0)
                    lbl.TextColor3 = Color3.fromRGB(255,255,255)
                    lbl.TextStrokeColor3 = cStroke
                    lbl.TextStrokeTransparency = transpStroke
                else
                    ApplySolid(cMain)
                    lbl.TextStrokeColor3 = cStroke
                    lbl.TextStrokeTransparency = transpStroke
                end
                
            -- ==========================================
            -- CORES ORIGINAIS RESTAURADAS EXATAMENTE COMO ANTES
            -- ==========================================
            elseif rank == "Owner" then
                grad.Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0, Color3.fromRGB(210, 210, 210)),
                    ColorSequenceKeypoint.new(0.5, Color3.fromRGB(255, 255, 255)),
                    ColorSequenceKeypoint.new(1, Color3.fromRGB(60, 60, 60))
                })
                grad.Offset = Vector2.new(metallicOffset * 0.7, 0)
                lbl.TextColor3 = Color3.fromRGB(255, 255, 255)
                lbl.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
                lbl.TextStrokeTransparency = 0
            elseif rank == "Co-Owner" then
                ApplyMetallic(Color3.fromRGB(90, 50, 20)) 
                lbl.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
                lbl.TextStrokeTransparency = 0
            elseif rank == "Supreme" then
                ApplyMetallic(Color3.fromRGB(0, 20, 100)) 
                lbl.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
                lbl.TextStrokeTransparency = 0
            elseif rank == "Contributor" then
                -- Laranja vibrante e profissional
                ApplyMetallic(Color3.fromRGB(255, 85, 0)) 
                lbl.TextStrokeColor3 = Color3.fromRGB(0, 0, 0) -- Borda Preta
                lbl.TextStrokeTransparency = 0
            elseif rank == "Helper" then
                -- Amarelo Ouro Escuro (Fica mais legível com borda branca)
                ApplyMetallic(Color3.fromRGB(255, 200, 0)) 
                lbl.TextStrokeColor3 = Color3.fromRGB(255, 255, 255) -- Borda Branca
                lbl.TextStrokeTransparency = 0   
            elseif rank == "Supervisor" then
                ApplyMetallic(Color3.fromRGB(60, 0, 90)) 
                lbl.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
                lbl.TextStrokeTransparency = 0
            elseif rank == "Manager" then
                ApplyMetallic(Color3.fromRGB(120, 0, 0)) 
                lbl.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
                lbl.TextStrokeTransparency = 0
            elseif rank == "Developer" then
                ApplyMetallic(Color3.fromRGB(180, 140, 0)) 
                lbl.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
                lbl.TextStrokeTransparency = 0
            elseif rank == "Marketing" then
                ApplyMetallic(Color3.fromRGB(0, 80, 0)) 
                lbl.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
                lbl.TextStrokeTransparency = 0
            elseif rank == "Influencer" then
                ApplySolid(Color3.fromRGB(255, 20, 147))
                lbl.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
                lbl.TextStrokeTransparency = 0.3
            elseif rank == "Ultimate" then
