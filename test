-- Lógica Mestra de Busca (Amigos e Públicos)
PopulateServers = function()
    if GUI.IsFetchingServers then return end
    GUI.IsFetchingServers = true
    GUI.RefreshServersBtn.Text = "⏳ SCANNING..."
    
    for _, v in pairs(GUI.ServerListContainer:GetChildren()) do
        if v:IsA("Frame") then v:Destroy() end
    end
    
    task.spawn(function()
        local layoutCount = 1
        
        -- PASSO 1: Buscar Servidores de Amigos via API Nativa
        local s_friends, friendsList = pcall(function() return game.Players.LocalPlayer:GetFriendsOnline(200) end)
        if s_friends and friendsList then
            for _, friend in ipairs(friendsList) do
                -- Verifica se o amigo está jogando o MESMO JOGO, mas em um servidor diferente
                if friend.PlaceId == game.PlaceId and friend.GameId ~= game.JobId and friend.GameId ~= "" then
                    GUI.RenderServerCard(
                        true, 
                        "🧑‍🤝‍🧑 FRIEND: " .. friend.UserName, 
                        "Status: Playing in another server", 
                        friend.GameId, 
                        layoutCount
                    )
                    layoutCount = layoutCount + 1
                end
            end
        end
        
        -- PASSO 2: Buscar Servidores Públicos via HTTP
        local s_public, result = pcall(function()
            return game:HttpGet("https://games.roblox.com/v1/games/" .. tostring(game.PlaceId) .. "/servers/Public?sortOrder=Desc&limit=100")
        end)
        
        if s_public and result then
            local decoded = game:GetService("HttpService"):JSONDecode(result)
            if decoded and decoded.data then
                for _, server in ipairs(decoded.data) do
                    if server.id ~= game.JobId and server.playing < server.maxPlayers then
                        local pingColor = server.ping < 100 and "#00ff99" or (server.ping < 200 and "#ffaa00" or "#ff4444")
                        local stats = "👥 <b>Players:</b> " .. server.playing .. "/" .. server.maxPlayers .. " | 📶 <b>Ping:</b> <font color='"..pingColor.."'>" .. tostring(server.ping) .. "ms</font>"
                        
                        GUI.RenderServerCard(
                            false, 
                            "🌐 PUBLIC SERVER", 
                            stats, 
                            server.id, 
                            layoutCount
                        )
                        layoutCount = layoutCount + 1
                    end
                end
            end
        end
        
        GUI.RefreshServersBtn.Text = "🔄 SCAN SERVERS & FRIENDS"
        GUI.IsFetchingServers = false
    end)
end

