_G.RemoteFlingConn = game:GetService("RunService").Heartbeat:Connect(function()
    if not remoteFlingActive then return end
    local char = game.Players.LocalPlayer.Character
    if not char then return end

    local mouse = game.Players.LocalPlayer:GetMouse()
    mouse.TargetFilter = char 

    local remoteCamera = char:FindFirstChild("Remote Camera")
    if remoteCamera then
        local partesParaMover = {}
        local cameraFolder = remoteCamera:FindFirstChild("Camera")
        if cameraFolder and cameraFolder:FindFirstChild("RootPart") then table.insert(partesParaMover, cameraFolder.RootPart) end
        local engineFolder = remoteCamera:FindFirstChild("Engine")
        if engineFolder and engineFolder:FindFirstChild("Collision") then table.insert(partesParaMover, engineFolder.Collision) end

        local alvoPosicao = nil
        local modoAtaque = false

        -- O Segredo do "Grude": Segue cegamente o HumanoidRootPart do currentPTarget
        if currentPTarget and currentPTarget.Character and currentPTarget.Character:FindFirstChild("HumanoidRootPart") then
            alvoPosicao = currentPTarget.Character.HumanoidRootPart.Position
            modoAtaque = true
        else
            alvoPosicao = mouse.Hit.Position + Vector3.new(0, 2, 0)
            if currentPTarget then 
                togglePTarget() -- Destrava automaticamente se o alvo sumir
            end 
        end

        for _, peca in ipairs(partesParaMover) do
            peca.Anchored = false 
            peca.CanCollide = false 
            
            local vel = Vector3.new(25000, 25000, 25000)
            peca.AssemblyLinearVelocity = Vector3.new(0, 1000, 0)
            peca.AssemblyAngularVelocity = vel
            peca.Velocity = Vector3.new(0, 1000, 0)
            peca.RotVelocity = vel

            if modoAtaque then
                peca.CFrame = CFrame.new(alvoPosicao)
            else
                peca.CFrame = peca.CFrame:Lerp(CFrame.new(alvoPosicao), 0.2)
            end
        end
    end
end)

