RefreshTagsUI = function()
    for _, v in pairs(GUI.TagsFrame:GetChildren()) do
        if v:IsA("Frame") or v:IsA("UIGridLayout") or v:IsA("UIListLayout") or v:IsA("UIPadding") then v:Destroy() end
    end
    
    local layout = Instance.new("UIGridLayout", GUI.TagsFrame)
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.CellPadding = UDim2.new(0, 12, 0, 12)
    layout.CellSize = UDim2.new(0.47, 0, 0, 65)

    local padding = Instance.new("UIPadding", GUI.TagsFrame)
    padding.PaddingTop = UDim.new(0, 15)
    padding.PaddingBottom = UDim.new(0, 30)

    local isAdmin_tagUI = false
    local unlockedTags_tagUI = {["User"] = true}
    
    local function processRole(r)
        if not r then return end
        if r == "Creator" or r == "Co-Owner" then r = "Owner" end
        if r == "Developers" or r == "Dev" then r = "Developer" end
        if r == "Disigner" or r == "Designer" then r = "Designer" end
        if r == "Members" then r = "Member" end

        unlockedTags_tagUI[r] = true
        if TagAdminRoles and TagAdminRoles[r] then isAdmin_tagUI = true end
        
        if r == "Owner" then
            local allTags = {"Member", "Influencer", "Ultimate", "Supreme", "Tester", "Helper", "Contributor", "Marketing", "Designer", "Developer", "Supervisor", "Manager", "Co-Owner", "Owner"}
            for _, t in ipairs(allTags) do unlockedTags_tagUI[t] = true end
        end
        if r == "Member" then unlockedTags_tagUI["Member"] = true end
        if r == "Influencer" then unlockedTags_tagUI["Member"] = true; unlockedTags_tagUI["Influencer"] = true end
        if r == "Ultimate" then unlockedTags_tagUI["Member"] = true; unlockedTags_tagUI["Ultimate"] = true end
        if r == "Supreme" then unlockedTags_tagUI["Member"] = true; unlockedTags_tagUI["Ultimate"] = true; unlockedTags_tagUI["Supreme"] = true end
    end

    processRole(GetFirebaseRank(game.Players.LocalPlayer))
    
    local userCustomData_tagUI = _G.CustomTagsConfig and _G.CustomTagsConfig[tostring(game.Players.LocalPlayer.UserId)]
    if userCustomData_tagUI then
        if userCustomData_tagUI.CustomName and userCustomData_tagUI.CustomName ~= "" then unlockedTags_tagUI["Custom"] = true end
        if userCustomData_tagUI.Unlocked then
            for k, v in pairs(userCustomData_tagUI.Unlocked) do
                local tName = type(k) == "number" and v or k
                if v == true or v == "true" or type(k) == "number" then 
                    processRole(tName) 
                end
            end
        end
    end

    if isAdmin_tagUI then
        unlockedTags_tagUI["Member"] = true; unlockedTags_tagUI["Ultimate"] = true; unlockedTags_tagUI["Supreme"] = true
    end

    local displayOrder_tagUI = {"User", "Custom", "Member", "Influencer", "Ultimate", "Supreme", "Tester", "Helper", "Contributor", "Marketing", "Designer", "Developer", "Supervisor", "Manager", "Co-Owner", "Owner"}
