    elseif actionName == "Stand" then setToggleState(GUI.StandBtn, true)
    elseif actionName == "Doggy" then setToggleState(GUI.DoggyBtn, true)
    elseif actionName == "Drag" then setToggleState(GUI.DragBtn, true)
