-- Erradica a animação antiga da memória e força a injeção da nova instantaneamente.
_G.S7xCurrentAnimSet = nil

_G.S7xApplyAnimations = function(char)
    if not _G.S7xCurrentAnimSet then return end
    task.spawn(function()
        local hum = char:WaitForChild("Humanoid", 5)
        local animate = char:WaitForChild("Animate", 5)
        
        if not animate or not hum then return end
        
        pcall(function()
            local set = _G.S7xCurrentAnimSet
            
            -- PASSO 1: Desliga o script nativo para cortar a comunicação
            animate.Disabled = true
            
            -- PASSO 2: A MORTE DA ANIMAÇÃO ANTIGA (Hard Memory Flush)
            local animator = hum:FindFirstChild("Animator") or hum:WaitForChild("Animator", 3)
            if animator then
                for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
                    track:Stop(0)
                    track:Destroy() -- Destrói a track antiga da memória RAM do Roblox
                end
            end
            
            -- PASSO 3: Injeta os novos IDs puros
            local function updateAnim(animName, trackName, id)
                if id and animate:FindFirstChild(animName) then
                    local realId = (id == "0" or id == 0 or id == "") and "" or "rbxassetid://" .. tostring(id:match("%d+") or id)
                    local stringId = (id == "0" or id == 0 or id == "") and "" or "http://www.roblox.com/asset/?id=" .. tostring(id:match("%d+") or id)
                    
                    local animObj = animate[animName]:FindFirstChild(trackName)
                    if animObj and animObj:IsA("Animation") then
                        animObj.AnimationId = realId
                    end
                    
                    local strVal = animate:FindFirstChild(animName)
                    if strVal and strVal:IsA("StringValue") then
                        strVal.Value = stringId
                    end
                end
            end

            updateAnim("idle", "Animation1", set.idle1)
            updateAnim("idle", "Animation2", set.idle2)
            updateAnim("walk", "WalkAnim", set.walk)
            updateAnim("run", "RunAnim", set.run)
            updateAnim("jump", "JumpAnim", set.jump)
            updateAnim("fall", "FallAnim", set.fall)
            updateAnim("climb", "ClimbAnim", set.climb)
            updateAnim("swimidle", "SwimIdle", set.swimidle)
            updateAnim("swim", "Swim", set.swim)
            
            -- PASSO 4: Aguarda 1 frame do motor do jogo para confirmar o "lixo" deletado
            game:GetService("RunService").RenderStepped:Wait()
            
            -- PASSO 5: Religa o script. O Roblox baixará a nova do zero e espalhará pro servidor.
            animate.Disabled = false
            hum:ChangeState(Enum.HumanoidStateType.Landed)
        end)
    end)
end

