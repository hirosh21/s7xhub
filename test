S7xUpdateMoveVFX = function(character, speed)
    if not _G.AurasVisible then return end
    marker_upd = character:FindFirstChild("S7xAuraMarker")
    aura_upd = marker_upd and marker_upd.Value or "None"
    if aura_upd == "None" then return end

    new_state = (speed <= 1 and "Idle") or (speed <= 18 and "Walk") or "Run"
    last_state_val = character:FindFirstChild("S7xLastState")
    if not last_state_val then last_state_val = Instance.new("StringValue", character); last_state_val.Name = "S7xLastState" end
    if last_state_val.Value == new_state then return end 
    last_state_val.Value = new_state

    feet_list = {"RightFoot", "LeftFoot", "Right Leg", "Left Leg"}
    for _, foot_name in ipairs(feet_list) do
        target_foot = character:FindFirstChild(foot_name)
        if target_foot then
            for _, child in ipairs(target_foot:GetChildren()) do if child.Name == "S7xMoveAtt" then child:Destroy() end end
            if S7xMovementVFX[aura_upd] and S7xMovementVFX[aura_upd][new_state] then
                new_att = Instance.new("Attachment", target_foot); new_att.Name = "S7xMoveAtt"; new_att.Position = Vector3.new(0, -0.8, 0)
                S7xMovementVFX[aura_upd][new_state](new_att)
            end
        end
    end
end

