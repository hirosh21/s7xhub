local function getMyTag()
    if _G.EquippedTag then return _G.EquippedTag end
    local success, role = pcall(function() return game.Players.LocalPlayer:GetRoleInGroup(34157675) end) 
    local isPerm = false
    if success and role and role ~= "Guest" then 
        if TagAdminRoles and (TagAdminRoles[role] or role == "Supreme" or role == "Ultimate" or role == "Influencer") then
            isPerm = true
        end
        if isPerm then
            if role == "Developers" then return "Dev" end
            if role == "Creator" then return "Owner" end
            if role == "Disigner" then return "Designer" end
            return role 
        end
    end
    if type(isTesterActive) == "function" and isTesterActive() and not isPerm then return "Tester" end
    return GetFirebaseRank(game.Players.LocalPlayer) or (success and role and role ~= "Guest" and role) or "User"
end

