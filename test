-- Função de Resincronização Absoluta de Tags (Conserta o sumiço dos nicks)
S7xResyncAllTags = function()
    task.spawn(function()
        task.wait(0.2) -- Dá um respiro para o motor do Roblox processar a troca de corpos
        for _, p in ipairs(game:GetService("Players"):GetPlayers()) do
            if p.Character then
                -- 1. Força o recarregamento do Nick nativo do Roblox
                hum_resync = p.Character:FindFirstChildOfClass("Humanoid")
                if hum_resync then
                    oldDist_resync = hum_resync.DisplayDistanceType
                    hum_resync.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None
                    task.wait()
                    hum_resync.DisplayDistanceType = (oldDist_resync ~= Enum.HumanoidDisplayDistanceType.None) and oldDist_resync or Enum.HumanoidDisplayDistanceType.Viewer
                end
                
                -- 2. Limpa a Tag S7x da cabeça para forçar uma reconstrução limpa
                head_resync = p.Character:FindFirstChild("Head") or p.Character:FindFirstChild("HumanoidRootPart")
                if head_resync then
                    for _, v in ipairs(head_resync:GetChildren()) do
                        if v.Name == "S7x_ProTag" then v:Destroy() end
                    end
                end
                
                -- 3. Reconstrói a tag visualmente
                if ApplyOrUpdateTag then ApplyOrUpdateTag(p) end
            end
        end
    end)
end

ToggleInvisibility = function()
    _G.InvisibleEnabled = not _G.InvisibleEnabled
    if setToggleState then setToggleState(GUI.InvisibleBtn, _G.InvisibleEnabled) end
    
    if _G.InvisibleEnabled then
        char_inv = game.Players.LocalPlayer.Character
        if char_inv and char_inv:FindFirstChild("HumanoidRootPart") then
            InvisRealChar = char_inv
            char_inv.Archivable = true
            InvisFakeChar = char_inv:Clone()
            InvisFakeChar.Parent = workspace
            game.Players.LocalPlayer.Character = InvisFakeChar
            workspace.CurrentCamera.CameraSubject = InvisFakeChar:FindFirstChild("Humanoid")
            
            -- Limpa scripts de animação antigos para evitar bugs de loop
            anim_inv = InvisFakeChar:FindFirstChild("Animate")
            if anim_inv then
                animClone_inv = anim_inv:Clone()
                anim_inv:Destroy()
                animClone_inv.Parent = InvisFakeChar
            end
            
            -- GHOST MODE: Material visual holográfico
            for _, v in ipairs(InvisFakeChar:GetDescendants()) do
                if v:IsA("BasePart") and v.Name ~= "HumanoidRootPart" then
                    v.Transparency = 0.5
                    v.Material = Enum.Material.ForceField
                elseif v:IsA("Decal") then
                    v.Transparency = 0.5
                end
            end
            
            -- Loop para manter seu corpo verdadeiro escondido abaixo do chão
            InvisLoop = game:GetService("RunService").Stepped:Connect(function()
                if InvisRealChar and InvisFakeChar and InvisRealChar:FindFirstChild("HumanoidRootPart") and InvisFakeChar:FindFirstChild("HumanoidRootPart") then
                    InvisRealChar.HumanoidRootPart.CFrame = InvisFakeChar.HumanoidRootPart.CFrame * CFrame.new(0, -250, 0)
                    InvisRealChar.HumanoidRootPart.Velocity = Vector3.zero
                    InvisRealChar.HumanoidRootPart.RotVelocity = Vector3.zero
                end
            end)
            
            S7xResyncAllTags()
        end
    else
        pcall(function()
            if InvisLoop then InvisLoop:Disconnect(); InvisLoop = nil end
            if InvisFakeChar and InvisRealChar then
                realHrp_inv = InvisRealChar:FindFirstChild("HumanoidRootPart")
                fakeHrp_inv = InvisFakeChar:FindFirstChild("HumanoidRootPart")
                
                -- Traz seu corpo verdadeiro de volta pra superfície suavemente
                if realHrp_inv and fakeHrp_inv then
                    realHrp_inv.CFrame = fakeHrp_inv.CFrame
                end
                
                game.Players.LocalPlayer.Character = InvisRealChar
                workspace.CurrentCamera.CameraSubject = InvisRealChar:FindFirstChild("Humanoid")
                InvisFakeChar:Destroy()
                InvisFakeChar = nil
                
                S7xResyncAllTags()
            end
        end)
    end
end

