                                    newTrack:Play()
                                    newTrack:AdjustSpeed(track.Speed)
                                    _G.ActiveSyncTracks[id] = newTrack
                                end
                            end
                        end
                    end
                    
                    for id, myTrack in pairs(_G.ActiveSyncTracks) do
                        if not currentlyPlaying[id] then
                            myTrack:Stop()
                            _G.ActiveSyncTracks[id] = nil
                        end
                    end
