local function lookAt(target)
    camera.CFrame = CFrame.new(camera.CFrame.Position, camera.CFrame.Position + (target - camera.CFrame.Position).unit)
end

local function getClosestPlayerInFOV(trg_part)
    local nearest, last = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Team ~= player.Team then
            local part = p.Character and p.Character:FindFirstChild(trg_part)
            if part then
                local ePos, isVisible = camera:WorldToViewportPoint(part.Position)
                local dist = (Vector2.new(ePos.x, ePos.y) - camera.ViewportSize / 2).Magnitude
                if dist < last and isVisible and ePos.Z < fovRadius and not workspace:Raycast(camera.CFrame.Position, part.Position - camera.CFrame.Position) then
                    last = dist
                    nearest = p
                end
            end
        end
    end
    return nearest
end

