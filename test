        ["Helper"] = Color3.fromRGB(255, 200, 0),
        ["Supervisor"] = Color3.fromRGB(60, 0, 90),
        ["Manager"] = Color3.fromRGB(120, 0, 0),
        ["Developer"] = Color3.fromRGB(180, 140, 0),
        ["Marketing"] = Color3.fromRGB(0, 150, 0),
        ["Influencer"] = Color3.fromRGB(216, 175, 255),
        ["Ultimate"] = Color3.fromRGB(0, 255, 255),
        ["Designer"] = Color3.fromRGB(0, 100, 255),
        ["Tester"] = Color3.fromRGB(139, 69, 19),
        ["Member"] = Color3.fromRGB(200, 200, 200),
        ["User"] = Color3.fromRGB(150, 150, 150),
        ["Custom"] = Color3.fromRGB(0, 255, 150)
