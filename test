        GUI.MainFrame.Position = shrinkPos
        GUI.MainFrame.Visible = true
        
        pcall(function()
            game:GetService("TweenService"):Create(GUI.MainFrame, TweenInfo.new(0.5, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out), {
                Size = panelTargetSize,
                Position = panelTargetPos
            }):Play()
