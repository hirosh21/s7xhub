_G.GetAdminTargetID = function()
    local txt = GUI.AdmTargetBox.Text
    if txt == "" then return nil end
    if tonumber(txt) then 
        local p = game:GetService("Players"):GetPlayerByUserId(tonumber(txt))
        return tonumber(txt), p 
    end
    local ltxt = string.lower(txt)
    for _, p in ipairs(game:GetService("Players"):GetPlayers()) do
        if string.sub(string.lower(p.Name), 1, #ltxt) == ltxt or string.sub(string.lower(p.DisplayName), 1, #ltxt) == ltxt then
            return p.UserId, p
        end
    end
    return nil
end

